# =========================================================================
# Conexao com o banco PostgreSQL + PostGIS (Neon).
# No Neon, copie a "Connection string" e mantenha o ?sslmode=require no final.
# Ex.: postgres://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
# =========================================================================
DATABASE_URL=

# Porta do servidor. No Render isto e definido automaticamente.
PORT=3000

# Senha opcional para a pagina de importacao de GeoJSON (/importar). Se definida,
# a pagina exige esse token para gravar dados (cabecalho x-import-token). Deixe
# vazio em desenvolvimento; em producao (site publico) e RECOMENDADO definir,
# senao qualquer pessoa poderia importar ou apagar os dados territoriais.
IMPORT_TOKEN=

# =========================================================================
# Autenticacao (modulos Demandas e, futuramente, BCI).
# AUTH_ENABLED desligado (padrao): ninguem precisa fazer login; os modulos
# ficam abertos e a tabela de usuarios serve so como diretorio de membros da
# equipe (para atribuir responsaveis). Ligue com "true" para exigir login e
# aplicar os 3 perfis (admin/coordenador/tecnico) — usado na aprovacao do BCI.
# =========================================================================
AUTH_ENABLED=false
# Segredo para assinar os tokens (usado so quando AUTH_ENABLED=true).
AUTH_SECRET=troque-por-um-segredo-longo-e-aleatorio
# Usuario administrador criado no primeiro boot (se a tabela estiver vazia).
ADMIN_EMAIL=admin@bzr.com
ADMIN_PASSWORD=bzr1234
# Se "true" e nao houver demandas, carrega demandas de demonstracao no boot.
SEED_DEMANDAS_DEMO=false

# Se "true" e o banco estiver VAZIO, carrega a cidade de demonstracao no boot.
# Util para um deploy de vitrine sem precisar rodar "npm run seed" manualmente.
# Deixe "false" quando for usar seus dados reais.
SEED_DEMO=false

# Se "true" e NAO houver nenhuma O.S., carrega ordens de servico de
# DEMONSTRACAO (Joao Pessoa) no boot — util para apresentar o modulo /os ao
# cliente. Nao apaga O.S. existentes. Tambem da para rodar "npm run seed-os".
# Deixe "false" quando for operar com dados reais.
SEED_OS_DEMO=false

# =========================================================================
# Camada de ORTOFOTO (tiles XYZ). Aceita {z}/{x}/{y} e, opcionalmente,
# {municipio} (substituido pela cidade selecionada, para uma ortofoto por
# cidade). Ex. multi-cidade no S3 (uma pasta por municipio):
#   https://eixo-ortofotos.s3.sa-east-1.amazonaws.com/{municipio}/{z}/{x}/{y}.png
# {municipio} vira um "slug" (minusculas, sem acento, espacos -> hifen). Ex.:
# "Tabira" -> tabira; "Catole do Rocha - PB" -> catole-do-rocha-pb. Nomeie as
# pastas no S3 com esse slug.
# Deixe vazio para usar a imagem de satelite publica (Esri) como referencia.
# Se SERVE_LOCAL_TILES=true e existir ./tiles/ortho, ela e exposta em
# /tiles/ortho/{z}/{x}/{y}.png automaticamente.
# =========================================================================
ORTHO_TILE_URL=
ORTHO_TILE_ATTRIBUTION=Ortofoto municipal
ORTHO_TILE_MINZOOM=0
ORTHO_TILE_MAXZOOM=22
SERVE_LOCAL_TILES=true

# =========================================================================
# Centro/zoom inicial do mapa (usado apenas se ainda nao houver dados
# carregados para calcular a extensao automaticamente).
# =========================================================================
MAP_CENTER_LAT=-22.0178
MAP_CENTER_LNG=-47.8908
MAP_ZOOM=14

# =========================================================================
# Modulo Ordens de Servico (/os) — sincronizacao de buracos reportados no
# Waze via BigQuery. Opcional: sem essas variaveis o modulo de O.S. funciona
# normalmente, so a sincronizacao com o Waze fica indisponivel.
# =========================================================================
WAZE_BQ_PROJECT=testes-waze
WAZE_BQ_DATASET=
WAZE_BQ_TABLE=
WAZE_BQ_LOCATION=US
# Token OAuth de curta duracao (~1h); normalmente informado pela tela de
# configuracao do /os em vez de fixado aqui. Gere com:
#   gcloud auth print-access-token
WAZE_TOKEN=
